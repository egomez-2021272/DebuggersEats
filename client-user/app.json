{
  "expo": {
    "name": "client-user",
    "slug": "client-user",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/DebuggersEats_logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/DebuggersEats_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0b0d"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.debuggerseats.clientuser"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/DebuggersEats_logo.png",
        "backgroundColor": "#0b0b0d"
      },
      "package": "com.debuggerseats.clientuser"
    },
    "web": {
      "favicon": "./assets/DebuggersEats_logo.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-sharing"
    ]
  }
}
